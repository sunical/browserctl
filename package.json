{
  "name": "browserctl",
  "version": "0.1.0",
  "description": "Browser automation CLI and library for AI agents",
  "type": "module",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "bin": {
    "browserctl": "./bin/browserctl.js"
  },
  "scripts": {
